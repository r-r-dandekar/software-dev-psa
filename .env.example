# Copy to .env.local and fill in. .env.local is gitignored.

# --- Supabase (free cloud project) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — bypasses RLS, server-only, never commit:
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (D16) — swappable by config, no code changes ---
# Dev default: google (free tier). Switch to anthropic for Claude.
AI_PROVIDER=google
AI_MODEL=gemini-2.5-flash
# Free key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Used only if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Inngest ---
# Local dev needs nothing. Cloud (later) uses these.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Linear (Step 4) ---
# Settings -> Security & access -> Personal API keys
LINEAR_API_KEY=

# --- GitHub (Step 5) ---
# Fine-grained PAT with read access to the repo (Contents + Pull requests)
GITHUB_TOKEN=
