# Copy to .env.local and fill in. .env.local is gitignored.

# --- Supabase (free cloud project) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (D16) ---
# Provider is swappable by config. Default provider: anthropic (Claude).
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5
# Not needed until Step 1 (no AI calls happen in Step 0).
ANTHROPIC_API_KEY=

# --- Inngest ---
# Local dev needs nothing. Cloud (later) uses these.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
